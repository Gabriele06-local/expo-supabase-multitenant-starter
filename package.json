{
  "name": "expo-supabase-multitenant-starter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "dev:web": "npm run dev --workspace=apps/web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset --linked",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db reset --linked",
    "db:types": "supabase gen types typescript --local > packages/supabase/src/database.types.ts",
    "db:studio": "supabase studio",
    "db:status": "supabase status",
    "functions:serve": "supabase functions serve --no-browser",
    "functions:deploy": "supabase functions deploy",
    "setup": "npm install && npm run db:migrate && npm run db:seed && npm run db:types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
